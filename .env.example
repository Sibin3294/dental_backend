# Server
PORT=3000

# Database (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/dental_app

# Auth — use a long random string in production
JWT_SECRET=change-me-to-a-strong-secret

# Email (Resend) — optional for local dev
RESEND_API_KEY=

# Push notifications — optional for local dev (JSON string of Firebase service account)
FIREBASE_SERVICE_ACCOUNT=
